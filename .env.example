SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
# Optional for Socket Mode (recommended for local dev)
SLACK_APP_TOKEN=xapp-...
SLACK_PORT=3000

# Optional: restrict ingestion to one channel
INVENTORY_CHANNEL_ID=C0123456789

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

GOOGLE_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_WORKSHEET_NAME=Delivery Log

# Option A (recommended for deployment): full JSON in one line
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option B (local): set path to a json key file
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
